        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="生成签名">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">import groovy.json.JsonOutput
import org.apache.commons.codec.digest.DigestUtils

// 生成唯一订单号
def timestamp = System.currentTimeMillis()
def nonce = UUID.randomUUID().toString().replace(&quot;-&quot;, &quot;&quot;).substring(0, 16)
def orderNo = &quot;P&quot; + timestamp + nonce

// 构建业务参数
def amount = new Random().nextInt(5000) + 100  // 100-5100元随机金额
def params = [
    merchantId: vars.get(&quot;merchant_id&quot;),
    orderNo: orderNo,
    amount: amount.toString(),
    currency: &quot;CNY&quot;,
    productDesc: &quot;压力测试商品&quot;,
    bankCardNo: vars.get(&quot;card_no&quot;),
    phone: vars.get(&quot;phone&quot;),
    bankCode: vars.get(&quot;bank_code&quot;),
    notifyUrl: &quot;http://localhost:8888/callback&quot;,  // 如果改了端口，这里也要改
    timestamp: timestamp.toString(),
    nonce: nonce
]

// 按Key排序后拼接
def sortedParams = params.sort()
def signContent = sortedParams.collect { k, v -&gt; &quot;$k=$v&quot; }.join(&quot;&amp;&quot;)

// 添加密钥（测试环境）
def secretKey = &quot;test-secret-key-123456&quot;
signContent += &quot;&amp;key=&quot; + secretKey

// MD5签名（实际项目可能用RSA）
def sign = DigestUtils.md5Hex(signContent).toUpperCase()

// 保存变量
vars.put(&quot;order_no&quot;, orderNo)
vars.put(&quot;amount&quot;, amount.toString())
vars.put(&quot;timestamp&quot;, timestamp.toString())
vars.put(&quot;nonce&quot;, nonce)
vars.put(&quot;sign&quot;, sign)

// 构建请求体
def requestBody = JsonOutput.toJson(params + [sign: sign])
vars.put(&quot;request_body&quot;, requestBody)

log.info(&quot;生成订单: ${orderNo}, 金额: ${amount}&quot;)</stringProp>
            <stringProp name="scriptLanguage">jexl2</stringProp>
          </JSR223PreProcessor>
